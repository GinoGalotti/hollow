# .NET build artifacts
src/**/bin/
src/**/obj/

# Godot build artifacts
hollow_wardens/.godot/
hollow_wardens/export/

# Godot mono/C# build output
hollow_wardens/.mono/
hollow_wardens/bin/
hollow_wardens/obj/
hollow_wardens/**/*.import

# Python
__pycache__/
*.pyc

# Secrets / local config
.env
.env.local
*.key
*.pem

# Logs & reports
*.log
reports/

# Temp / editor noise
*.tmp
*.bak
*.orig

# Stray zero-byte hook artifacts (punctuation/digit-only names like ",+", "{,", "0", "0)")
/[0-9]
/[0-9][),;+*]*
/[,;{}()\[\]+*!]*
# Code fragments accidentally used as filenames (e.g. "!c.IsDormant)")
/!*

# OS
.DS_Store
Thumbs.db

temp-message.txt

sim-results/
sim-output/
ui-test-output.txt
ui-test-screenshots/
*.ps1

# Claude-flow MCP auto-generated agent configs and metrics (not project files)
.claude-flow/
.claude/agents/
