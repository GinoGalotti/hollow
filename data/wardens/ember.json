{
  "warden_id": "ember",
  "version": "1.0",
  "name": "The Ember",
  "archetype": "Burst Damage / Glass Cannon",
  "flavor": "A dying fire spirit. Where it burns, corruption spreads — but so does destruction. Ember trades board health for raw power.",
  "element_affinity": {
    "primary": "Ash",
    "secondary": "Shadow",
    "tertiary": "Gale"
  },
  "hand_limit": 5,
  "starting_presence": {
    "territory": "I1",
    "count": 1
  },
  "passives": [
    {
      "id": "ash_trail",
      "name": "Scorching Path",
      "icon": "fire",
      "flavor": "Where the Ember walks, the land scorches. Every foothold is a wound in the world.",
      "description": "At Tide start, each territory with Ember presence gains 1 Corruption and all invaders there take 1 damage.",
      "trigger": "tide_start",
      "mechanic": "ash_trail",
      "upgrade": {
        "id": "ash_trail_u1",
        "description_key": "UPGRADE_PASSIVE_ASH_TRAIL",
        "effects": [
          {
            "type": "set_ability_param",
            "key": "ash_trail_damage",
            "value": 2
          }
        ]
      }
    },
    {
      "id": "flame_out",
      "name": "Nothing Burns Forever",
      "icon": "card_remove",
      "flavor": "Every flame consumes itself in the end. There is no coming back from the Ember's fire.",
      "description": "Playing a bottom removes the card permanently (no Dormancy), and its elements count ×3 instead of ×2 toward thresholds.",
      "trigger": "on_bottom_played",
      "mechanic": "flame_out",
      "upgrade": {
        "id": "flame_out_u1",
        "description_key": "UPGRADE_PASSIVE_FLAME_OUT",
        "effects": [
          {
            "type": "set_ability_param",
            "key": "flame_out_weave_refund",
            "value": 1
          }
        ]
      }
    },
    {
      "id": "scorched_earth",
      "name": "Scorched Earth",
      "icon": "dice_skull",
      "flavor": "When the smoke clears, nothing remains. The invaders who survived the fire will face the ash.",
      "description": "At Resolution, deal damage to all invaders equal to total corruption across presence territories. Then halve that corruption (round down).",
      "trigger": "on_resolution",
      "mechanic": "scorched_earth",
      "upgrade": {
        "id": "scorched_earth_u1",
        "description_key": "UPGRADE_PASSIVE_SCORCHED_EARTH",
        "effects": [
          {
            "type": "modify_threshold",
            "key": "scorched_earth_halve_divisor",
            "value": 3
          }
        ]
      }
    },
    {
      "id": "ember_fury",
      "name": "Rising Fury",
      "icon": "dice_sword",
      "flavor": "The more the land burns, the stronger the Ember becomes. Corruption is not a weakness — it is power.",
      "description": "All Ember card damage effects get +1 per territory at corruption Level 1+. Upgrade: also +2 per territory at Level 2+.",
      "trigger": "passive",
      "mechanic": "ember_fury",
      "upgrade": {
        "id": "ember_fury_u1",
        "description_key": "UPGRADE_PASSIVE_EMBER_FURY",
        "effects": [
          {
            "type": "set_ability_param",
            "key": "ember_fury_bonus",
            "value": 2
          }
        ]
      },
      "pool": true
    },
    {
      "id": "heat_wave",
      "name": "Heat Wave",
      "icon": "arrow_clockwise",
      "flavor": "Rest brings not peace, but a surge of searing heat. The invaders never see it coming.",
      "description": "On Rest, deal 2 damage to all invaders in ALL presence territories.",
      "trigger": "on_rest",
      "mechanic": "heat_wave",
      "upgrade": {
        "id": "heat_wave_u1",
        "description_key": "UPGRADE_PASSIVE_HEAT_WAVE",
        "effects": [
          {
            "type": "set_ability_param",
            "key": "heat_wave_damage",
            "value": 3
          }
        ]
      },
      "pool": true
    },
    {
      "id": "controlled_burn",
      "name": "Controlled Burn",
      "icon": "fire",
      "flavor": "The spirit reads the flames like a language. Where fires are tended, fear takes root.",
      "description": "At Tide start, if 3+ territories are at Corruption Level 1+, generate 2 Fear. Upgrade: also generate 5 more Fear if 3+ territories are at Level 2+.",
      "trigger": "on_tide_start",
      "mechanic": "controlled_burn",
      "params": {
        "min_territories": 3,
        "fear_generated": 2
      },
      "upgrade": {
        "id": "controlled_burn_u1",
        "description_key": "UPGRADE_PASSIVE_CONTROLLED_BURN",
        "effects": [
          {
            "type": "modify_threshold",
            "key": "controlled_burn_min",
            "value": 2
          }
        ]
      },
      "pool": true
    },
    {
      "id": "phoenix_spark",
      "name": "Phoenix Spark",
      "icon": "fire",
      "flavor": "Even in death, the Ember's fire frightens. A card destroyed is a flame passed on.",
      "description": "When any card is permanently removed (bottom or rest-dissolve), generate 3 Fear. Upgrade: generates 5 Fear instead.",
      "trigger": "on_card_permanent_removal",
      "mechanic": "phoenix_spark",
      "upgrade": {
        "id": "phoenix_spark_u1",
        "description_key": "UPGRADE_PASSIVE_PHOENIX_SPARK",
        "effects": [
          {
            "type": "set_ability_param",
            "key": "phoenix_spark_fear",
            "value": 5
          }
        ]
      },
      "pool": true
    }
  ],
  "resolution_style": "scorched_earth",
