      "pool": true
    },
    {
      "id": "presence_provocation",
      "name": "Protector's Call",
      "icon": "shield",
      "flavor": "The spirit's roots stir the Natives to action. In its shadow, they will not stand idle.",
      "description": "Natives in Presence territories counter-attack on every invader action, not just Ravage.",
      "trigger": "on_activate",
      "mechanic": "always_provoke",
      "upgrade": {
        "id": "presence_provocation_u1",
        "description_key": "UPGRADE_PASSIVE_PRESENCE_PROVOCATION",
        "effects": [
          {
            "type": "set_ability_param",
            "key": "provocation_range",
            "value": 1
          }
        ]
      },
      "pool": true
    },
    {
      "id": "rest_growth",
      "name": "Deep Breath",
      "icon": "campfire",
      "flavor": "Even in stillness, the roots creep forward. Rest is not weakness — it is growth.",
