  "passives": [
    {
      "id": "network_fear",
      "name": "The Web Remembers",
      "icon": "token",
      "flavor": "Where roots intertwine, the land whispers of what was lost. Invaders feel it in their bones.",
      "description": "Each turn, generate 1 Fear per invader in a territory adjacent to 3+ Presence territories (max 3 Fear).",
      "trigger": "turn_start",
      "mechanic": "network_fear",
      "upgrade": {
        "id": "network_fear_u1",
        "description_key": "UPGRADE_PASSIVE_NETWORK_FEAR",
        "effects": [
          {
            "type": "set_balance",
            "key": "network_fear_cap",
            "value": 6
          }
        ]
      }
    },
    {
      "id": "network_slow",
      "name": "Tangled Earth",
      "icon": "hexagon",
      "flavor": "The ground itself resists. Every step is a struggle through grasping soil.",
      "description": "Invaders in a territory adjacent to 3+ Presence territories have -1 Advance movement.",
      "trigger": "on_advance",
      "mechanic": "network_slow",
      "params": {
        "min_adjacent_presence": 3,
        "movement_penalty": 1
      },
      "upgrade": {
        "id": "network_slow_u1",
        "description_key": "UPGRADE_PASSIVE_NETWORK_SLOW",
